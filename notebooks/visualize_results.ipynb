 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔋 Ablation Study Results Analyzer\n",
    "\n",
    "This notebook provides an interactive dashboard to inspect, filter, and compare the results of the DINOv3 + PEFT anomaly detection ablation runs. \n",
    "\n",
    "It loads run configs and metrics from the `outputs` directory (including in-progress or interrupted runs by falling back to the latest checkpoint states) and displays:\n",
    "1. **Interactive Leaderboard**: Filter by task, backbone, PEFT, imbalance strategy, and learning rate.\n",
    "2. **Training & Eval Curves**: Compare loss and F1 trajectories across multiple runs using Plotly."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. Imports and environment setup\n",
    "import os\n",
    "import glob\n",
    "import json\n",
    "import yaml\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "import plotly.graph_objects as go\n",
    "import plotly.express as px\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, HTML\n",
    "\n",
    "# Set pandas options for readability\n",
    "pd.set_option('display.max_columns', None)\n",
    "pd.set_option('display.max_colwidth', None)\n",
    "pd.set_option('display.width', 1000)\n",
    "\n",
    "print(\"✅ Setup complete. Plotly and Widgets loaded.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. Recursive results loader\n",
    "\n",
    "def find_latest_checkpoint_state(run_dir):\n",
    "    \"\"\"\n",
    "    Locate the latest checkpoint folder inside a run directory and return\n",
    "    the path to its trainer_state.json if it exists.\n",
    "    \"\"\"\n",
    "    checkpoints = glob.glob(os.path.join(run_dir, \"checkpoint-*\"))\n",
    "    if not checkpoints:\n",
    "        return None\n",
    "    \n",
    "    # Sort checkpoints numerically by step number\n",
    "    def get_step(path):\n",
    "        try:\n",
    "            return int(path.split(\"-\")[-1])\n",
    "        except ValueError:\n",
    "            return -1\n",
    "            \n",
    "    checkpoints.sort(key=get_step, reverse=True)\n",
    "    for ckpt in checkpoints:\n",
    "        state_path = os.path.join(ckpt, \"trainer_state.json\")\n",
    "        if os.path.exists(state_path):\n",
    "            return state_path\n",
    "    return None\n",
    "\n",
    "def load_results(base_path=\"outputs\"):\n",
    "    \"\"\"\n",
    "    Recursively scans base_path to load config.yaml and trainer_state.json files.\n",
    "    \"\"\"\n",
    "    runs_data = []\n",
    "    base_path_obj = Path(base_path)\n",
    "    \n",
    "    if not base_path_obj.exists():\n",
    "        print(f" + 'f"❌ Error: Outputs path \\\'{base_path}\\\' does not exist."' + \")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "    # Locate directories containing config.yaml\n",
    "    for root, dirs, files in os.walk(base_path):\n",
    "        if \"log\" in root or \"runs\" in root:\n",
    "            continue\n",
    "            \n",
    "        if \"config.yaml\" in files:\n",
    "            run_dir = Path(root)\n",
    "            config_path = run_dir / \"config.yaml\"\n",
    "            \n",
    "            # 1. Parse config.yaml\n",
    "            try:\n",
    "                with open(config_path, \"r\") as f:\n",
    "                    cfg = yaml.safe_load(f)\n",
    "            except Exception as e:\n",
    "                print(f" + 'f"⚠️ Error parsing config at {config_path}: {e}"' + \")\n",
    "                continue\n",
    "                \n",
    "            # Extract config values (with fallbacks)\n",
    "            model_name = cfg.get(\"model_name\", \"unknown\")\n",
    "            peft_cfg = cfg.get(\"peft\", {})\n",
    "            peft_type = peft_cfg.get(\"type\", \"none\")\n",
    "            \n",
    "            imb_cfg = cfg.get(\"imbalance\", {})\n",
    "            imbalance_strategy = imb_cfg.get(\"strategy\") or imb_cfg.get(\"oversampling_method\") or \"none\"\n",
    "            \n",
    "            # Resolve specific PEFT details\n",
    "            peft_detail = \"none\"\n",
    "            if peft_type == \"lora\":\n",
    "                peft_detail = f" + 'f"r={peft_cfg.get(\\\'lora_r\\\', 8)}"' + \"\n",
    "            elif peft_type == \"adapter\":\n",
    "                peft_detail = f" + 'f"d={peft_cfg.get(\\\'adapter_bottleneck_dim\\\', 64)}"' + \"\n",
    "            elif peft_type == \"visual_prompt\":\n",
    "                peft_detail = f" + 'f"t={peft_cfg.get(\\\'vpt_num_tokens\\\', 10)}"' + \"\n",
    "            \n",
    "            # Placeholders for future task/hyperparameter expansion\n",
    "            task = \"cls\"  # default task; can expand to \"seg\", \"det\", etc.\n",
    "            custom_param = \"default\"  # placeholder for other custom configurations\n",
    "            \n",
    "            # 2. Parse trainer_state.json (look in root, fallback to latest checkpoint)\n",
    "            state_path = run_dir / \"trainer_state.json\"\n",
    "            if not state_path.exists():\n",
    "                checkpoint_state = find_latest_checkpoint_state(run_dir)\n",
    "                if checkpoint_state:\n",
    "                    state_path = Path(checkpoint_state)\n",
    "            \n",
    "            history = []\n",
    "            best_eval_f1 = 0.0\n",
    "            best_eval_loss = float('inf')\n",
    "            final_train_loss = None\n",
    "            completed = \"DONE\" in files\n",
    "            \n",
    "            if state_path.exists():\n",
    "                try:\n",
    "                    with open(state_path, \"r\") as f:\n",
    "                        state = json.load(f)\n",
    "                    \n",
    "                    history = state.get(\"log_history\", [])\n",
    "                    best_eval_f1 = state.get(\"best_metric\") or 0.0\n",
    "                    \n",
    "                    # Extract max F1 and min Loss from evaluation steps in history\n",
    "                    eval_f1s = [item.get(\"eval_f1\") for item in history if \"eval_f1\" in item]\n",
    "                    eval_losses = [item.get(\"eval_loss\") for item in history if \"eval_loss\" in item]\n",
    "                    train_losses = [item.get(\"loss\") for item in history if \"loss\" in item]\n",
    "                    \n",
    "                    if eval_f1s:\n",
    "                        best_eval_f1 = max(eval_f1s)\n",
    "                    if eval_losses:\n",
    "                        best_eval_loss = min(eval_losses)\n",
    "                    if train_losses:\n",
    "                        final_train_loss = train_losses[-1]\n",
    "                        \n",
    "                except Exception as e:\n",
    "                    print(f" + 'f"⚠️ Error parsing state at {state_path}: {e}"' + \")\n",
    "            \n",
    "            runs_data.append({\n",
    "                \"dir\": str(run_dir.relative_to(base_path_obj)),\n",
    "                \"config_name\": run_dir.parent.name if run_dir.parent.name != base_path_obj.name else run_dir.name,\n",
    "                \"task\": task,\n",
    "                \"model\": model_name,\n",
    "                \"peft_type\": peft_type,\n",
    "                \"peft_detail\": peft_detail,\n",
    "                \"imbalance_strategy\": imbalance_strategy,\n",
    "                \"lr\": cfg.get(\"learning_rate\", 0.0),\n",
    "                \"epochs_configured\": cfg.get(\"num_epochs\", 0),\n",
    "                \"custom_param\": custom_param, # placeholder\n",
    "                \"best_eval_f1\": best_eval_f1,\n",
    "                \"best_eval_loss\": best_eval_loss if best_eval_loss != float('inf') else None,\n",
    "                \"final_train_loss\": final_train_loss,\n",
    "                \"completed\": completed,\n",
    "                \"history\": history\n",
    "            })\n",
    "            \n",
    "    return pd.DataFrame(runs_data)\n",
    "\n",
    "# Search outputs directory (checks typical notebook folder location relative to root)\n",
    "base_path = \"../outputs\" if os.path.exists(\"../outputs\") else \"outputs\"\n",
    "df_results = load_results(base_path)\n",
    "print(f" + 'f"Loaded {len(df_results)} runs from {base_path}."' + \")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. Display the raw leaderboard data\n",
    "if not df_results.empty:\n",
    "    # Sort leaderboard by validation F1 descending\n",
    "    leaderboard = df_results.sort_values(by=\"best_eval_f1\", ascending=False).copy()\n",
    "    # Display top 15 runs\n",
    "    display(HTML(\"<h3>🏆 Top 15 Leaderboard (Sorted by Best Eval F1)</h3>\"))\n",
    "    cols_to_show = [\"dir\", \"task\", \"model\", \"peft_type\", \"peft_detail\", \"imbalance_strategy\", \"lr\", \"best_eval_f1\", \"best_eval_loss\", \"completed\"]\n",
    "    display(leaderboard[cols_to_show].head(15))\n",
    "else:\n",
    "    print(\"❌ No results found. Please check that training outputs are in outputs/ directory.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. Interactive widgets filtering dashboard\n",
    "\n",
    "if not df_results.empty:\n",
    "    # Define widget controls\n",
    "    # Placeholders for future extensions (e.g. task types, architectures)\n",
    "    w_task = widgets.Dropdown(\n",
    "        options=[\"All\"] + list(df_results[\"task\"].unique()),\n",
    "        value=\"All\",\n",
    "        description=\"Task:\"\n",
    "    )\n",
    "    w_model = widgets.Dropdown(\n",
    "        options=[\"All\"] + list(df_results[\"model\"].unique()),\n",
    "        value=\"All\",\n",
    "        description=\"Model:\"\n",
    "    )\n",
    "    w_peft = widgets.Dropdown(\n",
    "        options=[\"All\"] + list(df_results[\"peft_type\"].unique()),\n",
    "        value=\"All\",\n",
    "        description=\"PEFT Type:\"\n",
    "    )\n",
    "    w_imb = widgets.Dropdown(\n",
    "        options=[\"All\"] + list(df_results[\"imbalance_strategy\"].unique()),\n",
    "        value=\"All\",\n",
    "        description=\"Imbalance:\"\n",
    "    )\n",
    "    w_lr = widgets.Dropdown(\n",
    "        options=[\"All\"] + sorted(list(df_results[\"lr\"].unique().astype(str))),\n",
    "        value=\"All\",\n",
    "        description=\"Learning Rate:\"\n",
    "    )\n",
    "    \n",
    "    ui = widgets.VBox([\n",
    "        widgets.HTML(\"<h4>🔍 Filter Leaderboard</h4>\"),\n",
    "        widgets.HBox([w_task, w_model, w_peft]),\n",
    "        widgets.HBox([w_imb, w_lr])\n",
    "    ])\n",
    "    \n",
    "    def filter_and_display(task, model, peft, imbalance, lr):\n",
    "        filtered_df = df_results.copy()\n",
    "        \n",
    "        if task != \"All\":\n",
    "            filtered_df = filtered_df[filtered_df[\"task\"] == task]\n",
    "        if model != \"All\":\n",
    "            filtered_df = filtered_df[filtered_df[\"model\"] == model]\n",
    "        if peft != \"All\":\n",
    "            filtered_df = filtered_df[filtered_df[\"peft_type\"] == peft]\n",
    "        if imbalance != \"All\":\n",
    "            filtered_df = filtered_df[filtered_df[\"imbalance_strategy\"] == imbalance]\n",
    "        if lr != \"All\":\n",
    "            filtered_df = filtered_df[filtered_df[\"lr\"] == float(lr)]\n",
    "            \n",
    "        sorted_df = filtered_df.sort_values(by=\"best_eval_f1\", ascending=False)\n",
    "        \n",
    "        display(HTML(f\"<b>Found {len(sorted_df)} matching runs</b>\"))\n",
    "        cols = [\"dir\", \"task\", \"peft_type\", \"peft_detail\", \"imbalance_strategy\", \"lr\", \"best_eval_f1\", \"best_eval_loss\", \"completed\"]\n",
    "        display(sorted_df[cols])\n",
    "        \n",
    "    out = widgets.interactive_output(filter_and_display, {\n",
    "        'task': w_task,\n",
    "        'model': w_model,\n",
    "        'peft': w_peft,\n",
    "        'imbalance': w_imb,\n",
    "        'lr': w_lr\n",
    "    })\n",
    "    \n",
    "    display(ui, out)\n",
    "else:\n",
    "    print(\"No data available to filter.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5. Plotly curves comparator\n",
    "\n",
    "if not df_results.empty:\n",
    "    display(HTML(\"<h3>📈 Compare Training History</h3>\"))\n",
    "    \n",
    "    # Selection widget to choose runs to plot\n",
    "    run_options = {row['dir']: idx for idx, row in df_results.iterrows()}\n",
    "    w_select_runs = widgets.SelectMultiple(\n",
    "        options=run_options,\n",
    "        value=list(run_options.values())[:min(3, len(run_options))],\n",
    "        description='Select Runs:',\n",
    "        style={'description_width': 'initial'},\n",
    "        layout={'width': '80%', 'height': '150px'}\n",
    "    )\n",
    "    \n",
    "    w_metric_type = widgets.ToggleButtons(\n",
    "        options=['eval_f1', 'eval_loss', 'loss (train)', 'eval_accuracy', 'eval_auroc'],\n",
    "        description='Metric:',\n",
    "        button_style='info'\n",
    "    )\n",
    "    \n",
    "    plot_ui = widgets.VBox([w_select_runs, w_metric_type])\n",
    "    \n",
    "    def update_plots(selected_indices, metric):\n",
    "        if not selected_indices:\n",
    "            print(\"Please select at least one run to plot.\")\n",
    "            return\n",
    "            \n",
    "        fig = go.Figure()\n",
    "        \n",
    "        for idx in selected_indices:\n",
    "            run = df_results.loc[idx]\n",
    "            history = run['history']\n",
    "            \n",
    "            if not history:\n",
    "                continue\n",
    "                \n",
    "            epochs = []\n",
    "            values = []\n",
    "            \n",
    "            # Handle train loss vs eval metrics\n",
    "            if metric == 'loss (train)':\n",
    "                key = 'loss'\n",
    "            else:\n",
    "                key = metric\n",
    "                \n",
    "            for log_entry in history:\n",
    "                if key in log_entry and 'epoch' in log_entry:\n",
    "                    epochs.append(log_entry['epoch'])\n",
    "                    values.append(log_entry[key])\n",
    "            \n",
    "            if epochs:\n",
    "                # Sort by epoch to guarantee line continuity\n",
    "                sort_idx = np.argsort(epochs)\n",
    "                epochs = np.array(epochs)[sort_idx]\n",
    "                values = np.array(values)[sort_idx]\n",
    "                \n",
    "                label = f\"{run['peft_type']} ({run['peft_detail']}) | lr={run['lr']} | {run['config_name'][:20]}\"\n",
    "                fig.add_trace(go.Scatter(\n",
    "                    x=epochs,\n",
    "                    y=values,\n",
    "                    mode='lines+markers',\n",
    "                    name=label,\n",
    "                    marker=dict(size=4)\n",
    "                ))\n",
    "                \n",
    "        fig.update_layout(\n",
    "            title=f\"{metric} curves across selected configurations\",\n",
    "            xaxis_title=\"Epoch\",\n",
    "            yaxis_title=metric,\n",
    "            template=\"plotly_dark\",\n",
    "            hovermode=\"x unified\",\n",
    "            legend=dict(yanchor=\"top\", y=-0.2, xanchor=\"left\", x=0.0)\n",
    "        )\n",
    "        fig.show()\n",
    "        \n",
    "    plot_out = widgets.interactive_output(update_plots, {\n",
    "        'selected_indices': w_select_runs,\n",
    "        'metric': w_metric_type\n",
    "    })\n",
    "    \n",
    "    display(plot_ui, plot_out)\n",
    "else:\n",
    "    print(\"No runs available to plot.\")"
   ]
  }
 ],
